# Firebase / Django Production Environment Variables

# Security
SECRET_KEY=django-insecure-=m8uup@)$+h+ky_8wlh^=cdm&=l1mb-$a^1#_)(2nke9ye%51f
DEBUG=False

# Database Configuration (PostgreSQL recommended)
# Get this URL from your database provider (e.g., Supabase, Neon, Google Cloud SQL)
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
# If commented out, the app will fall back to local db.sqlite3
# DATABASE_URL=postgres://your_user:your_password@your_host:5432/your_db_name

# Google Cloud Storage (Firebase Storage)
# Get your bucket name from Firebase Console -> Storage (format is usually your-project-id.appspot.com)
# If left blank, the app will fall back to local /media/ storage
# GS_BUCKET_NAME=your-firebase-project.appspot.com

# Firebase Authentication (Backend Verification)
# Path to your service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=path/to/your/service-account.json

# Payment Gateway (Razorpay)
# RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID
# RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET
